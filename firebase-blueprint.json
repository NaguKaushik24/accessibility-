{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile information like first name and last name.",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "User's first name"
        },
        "lastName": {
          "type": "string",
          "description": "User's last name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user profile was created"
        }
      },
      "required": ["firstName", "lastName", "email", "createdAt"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session containing multiple messages.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this chat"
        },
        "title": {
          "type": "string",
          "description": "A generated title/label for the chat"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chat was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chat was last updated"
        }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message within a chat session.",
      "type": "object",
      "properties": {
        "chatId": {
          "type": "string",
          "description": "The ID of the parent chat session"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this message"
        },
        "role": {
          "type": "string",
          "enum": ["user", "assistant"],
          "description": "The role of the message sender"
        },
        "content": {
          "type": "string",
          "description": "The text content of the message"
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "Serialized attachments for the message"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was created"
        }
      },
      "required": ["chatId", "userId", "role", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": {
        "$ref": "#/entities/ChatSession"
      },
      "description": "Chat sessions owned by users"
    },
    "/messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/ChatMessage"
      },
      "description": "Messages belonging to chat sessions"
    }
  }
}
